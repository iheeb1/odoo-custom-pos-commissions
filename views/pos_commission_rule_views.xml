<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Commission Rule List View -->
        <record id="view_pos_commission_rule_tree" model="ir.ui.view">
            <field name="name">pos.commission.rule.list</field>
            <field name="model">pos.commission.rule</field>
            <field name="arch" type="xml">
                <list string="Commission Rules">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="pos_config_ids" widget="many2many_tags" optional="show"/>
                    <field name="commission_type"/>
                    <field name="rate" string="Amount"/>
                    <field name="threshold_qty" optional="show"/>
                    <field name="threshold_rate" optional="show"/>
                    <field name="apply_on"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- Commission Rule Form View -->
        <record id="view_pos_commission_rule_form" model="ir.ui.view">
            <field name="name">pos.commission.rule.form</field>
            <field name="model">pos.commission.rule</field>
            <field name="arch" type="xml">
                <form string="Commission Rule">
                    <header>
                        <field name="active" widget="boolean_toggle"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group string="Commission Type">
                                <field name="commission_type"/>
                                <field name="rate" string="Amount" invisible="commission_type == 'fixed_after_threshold'"/>
                                <field name="threshold_qty" invisible="commission_type != 'fixed_after_threshold'"/>
                                <field name="threshold_rate" invisible="commission_type != 'fixed_after_threshold'"/>
                                <field name="calc_base" invisible="commission_type != 'percentage'"/>
                            </group>
                            <group string="Validity">
                                <field name="date_from"/>
                                <field name="date_to"/>
                            </group>
                        </group>
                        <group string="Apply On">
                            <field name="apply_on" widget="radio"/>
                            <field name="category_ids" 
                                   widget="many2many_tags"
                                   invisible="apply_on != 'product_category'"/>
                            <field name="product_ids"
                                   widget="many2many_tags"
                                   invisible="apply_on != 'product'"/>
                        </group>
                        <group string="Restrictions">
                            <group string="POS Locations">
                                <field name="pos_config_ids" widget="many2many_tags" placeholder="Leave empty for all POS locations"/>
                            </group>
                            <group string="Employees">
                                <field name="employee_ids" widget="many2many_tags" placeholder="Leave empty for all employees"/>
                            </group>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="sequence"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Commission Rule Search View -->
        <record id="view_pos_commission_rule_search" model="ir.ui.view">
            <field name="name">pos.commission.rule.search</field>
            <field name="model">pos.commission.rule</field>
            <field name="arch" type="xml">
                <search string="Search Commission Rules">
                    <field name="name"/>
                    <field name="pos_config_ids"/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <!-- Commission Rule Action -->
        <record id="action_pos_commission_rule" model="ir.actions.act_window">
            <field name="name">Commission Rules</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">pos.commission.rule</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_pos_commission_rule_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first commission rule
                </p>
                <p>
                    Commission rules define how commissions are calculated for your workers.
                    You can assign different rules to different POS locations.
                </p>
            </field>
        </record>

        <!-- Menu Items -->
        <menuitem id="menu_pos_commission_root"
                  name="Commissions"
                  parent="point_of_sale.menu_point_of_sale"
                  sequence="50"/>

        <menuitem id="menu_pos_commission_rule"
                  name="Commission Rules"
                  parent="menu_pos_commission_root"
                  action="action_pos_commission_rule"
                  sequence="10"/>
    </data>
</odoo>
