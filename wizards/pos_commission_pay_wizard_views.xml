<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_commission_pay_wizard_form" model="ir.ui.view">
        <field name="name">pos.commission.pay.wizard.form</field>
        <field name="model">pos.commission.pay.wizard</field>
        <field name="arch" type="xml">
            <form string="Pay Commissions">
                <group>
                    <group>
                        <field name="journal_id"/>
                        <field name="payment_date"/>
                    </group>
                    <group>
                        <field name="total_amount"/>
                    </group>
                </group>
                <group string="Commission Lines">
                    <field name="commission_line_ids" nolabel="1">
                        <list create="false" delete="false">
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="order_id"/>
                            <field name="commission_amount"/>
                            <field name="date"/>
                        </list>
                    </field>
                </group>
                <footer>
                    <button name="action_pay" string="Pay" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pos_commission_pay_wizard" model="ir.actions.act_window">
        <field name="name">Pay Commissions</field>
        <field name="res_model">pos.commission.pay.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
