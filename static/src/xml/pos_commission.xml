<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_sales_commission.CommissionWorkerPopup">
        <Dialog size="'lg'">
            <t t-set-slot="header">
                <h4 class="modal-title">Select Commission Workers</h4>
            </t>
            <div class="commission-worker-popup p-3">
                <div class="alert alert-info mb-3">
                    <i class="fa fa-info-circle me-2"/>
                    Select the worker who will receive the commission for this order.
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Commission Worker</label>
                    <select class="form-select" t-on-change="onSelectEmployee">
                        <option value="" t-att-selected="state.selectedEmployee === null">
                            Session Cashier (default)
                        </option>
                        <t t-foreach="props.employees" t-as="emp" t-key="emp.id">
                            <option t-att-value="emp.id"
                                    t-att-selected="state.selectedEmployee === emp.id">
                                <t t-esc="emp.name"/>
                            </option>
                        </t>
                    </select>
                </div>

                <div class="order-summary mt-3">
                    <h6>Order Lines</h6>
                    <div class="list-group">
                        <t t-foreach="props.order.lines" t-as="line" t-key="line.uuid">
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span t-esc="line.product_id.name"/>
                                <span class="badge bg-secondary">Qty: <t t-esc="line.qty"/></span>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-secondary btn-lg" t-on-click="onCancel">
                    <i class="fa fa-times me-2"/>Cancel
                </button>
                <button class="btn btn-primary btn-lg" t-on-click="onConfirm">
                    <i class="fa fa-check me-2"/>Confirm
                </button>
            </t>
        </Dialog>
    </t>

    <!-- Add commission employee to receipt -->
    <t t-name="pos_sales_commission.OrderReceiptCommission" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt')]" position="inside">
            <t t-if="commissionWorkerName">
                <div style="text-align:center; margin-top:4px;">
                    <span style="font-weight:bold;">Employee: </span><t t-esc="commissionWorkerName"/>
                </div>
            </t>
        </xpath>
    </t>

</templates>
