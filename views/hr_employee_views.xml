<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Extend Employee Form -->
        <record id="view_employee_form_commission" model="ir.ui.view">
            <field name="name">hr.employee.form.commission</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='payroll_group']" position="inside">
                    <group name="commission" string="Commission Settings">
                        <field name="commission_enabled"/>
                        <field name="commission_account_id" invisible="not commission_enabled"/>
                    </group>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="%(action_pos_commission_line)d" type="action"
                            class="oe_stat_button" icon="fa-money"
                            invisible="not commission_enabled">
                        <field name="commission_due" widget="statinfo" string="Due Commission"/>
                    </button>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
